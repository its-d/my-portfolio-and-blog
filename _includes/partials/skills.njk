<section class="skills" id="skills">
  <div class="section-head">
    <h2 class="section-title">#skills</h2>
    <p class="eyebrow eyebrow-com">the stack</p>
  </div>

  <p class="skills-row-label"><span class="code-glyph">//</span> cloud · iac · languages · runtime · os</p>
  <div class="skills-pill-grid">
    {% for skill in skills %}
      {% if loop.index <= 5 %}
      <span class="pill skill-pill">{{ skill.name }}</span>
      {% endif %}
    {% endfor %}
  </div>

  <p class="skills-row-label"><span class="code-glyph">//</span> vcs · ci · observability · data · practices</p>
  <div class="skills-pill-grid">
    {% for skill in skills %}
      {% if loop.index > 5 %}
      <span class="pill skill-pill">{{ skill.name }}</span>
      {% endif %}
    {% endfor %}
  </div>
</section>
